<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/background">

    <!-- App title – emoji is decorative, meaningful text follows -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Team Alpha 🚀"
        android:contentDescription="@string/group_name"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp" />

    <!-- Mode badge (Demo / Production) -->
    <TextView
        android:id="@+id/tvMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🟡 Demo Mode"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="40dp" />

    <!-- Summarize button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSummarize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_summarize"
        android:textSize="16sp"
        android:paddingHorizontal="28dp"
        android:paddingVertical="12dp" />

    <!-- Hint text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tap_hint"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="16dp" />

</LinearLayout>
